<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hisab-kitab App</title>
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css"
      rel="stylesheet"
    />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* Background Animation */
      body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: 
          radial-gradient(circle at 20% 80%, rgba(120, 119, 198, 0.3) 0%, transparent 50%),
          radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
          radial-gradient(circle at 40% 40%, rgba(120, 119, 198, 0.2) 0%, transparent 50%);
        z-index: -1;
        animation: float 20s ease-in-out infinite;
      }

      @keyframes float {
        0%, 100% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(1deg); }
      }

      main {
        position: relative;
        z-index: 1;
      }

      /* Navigation Styles */
      nav {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        padding: 1rem 2.5rem;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      }

      nav h3 {
        font-size: 1.8rem;
        font-weight: 700;
        color: white;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      nav h3::before {
        content: '📊';
        font-size: 1.5rem;
      }

      .navlinks {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .navlinks a {
        color: rgba(255, 255, 255, 0.9);
        text-decoration: none;
        font-weight: 500;
        padding: 0.5rem 1rem;
        border-radius: 25px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
      }

      .navlinks a::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.5s;
      }

      .navlinks a:hover::before {
        left: 100%;
      }

      .navlinks a:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
      }

      /* Main Content */
      .hisaabs {
        padding: 2.5rem;
        max-width: 1200px;
        margin: 0 auto;
      }

      .hisaabs h3 {
        font-size: 2.5rem;
        font-weight: 600;
        color: white;
        margin-bottom: 2rem;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
        position: relative;
      }

      .hisaabs h3::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 0;
        width: 60px;
        height: 4px;
        background: linear-gradient(90deg, #fff, transparent);
        border-radius: 2px;
      }

      /* Hisaab Cards */
      .hisaab {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        padding: 1.5rem 2rem;
        margin-bottom: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      }

      .hisaab::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
        transition: left 0.6s;
      }

      .hisaab:hover::before {
        left: 100%;
      }

      .hisaab:hover {
        transform: translateY(-5px) scale(1.02);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.2);
        background: rgba(255, 255, 255, 0.25);
      }

      .hisaab h3 {
        font-size: 1.5rem;
        color: white;
        font-weight: 600;
        text-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
        margin: 0;
      }

      .hisaab h3::after {
        display: none;
      }

      /* Icon Styles */
      .hisaab i {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: all 0.3s ease;
        cursor: pointer;
        font-size: 1.1rem;
      }

      .ri-arrow-right-line {
        background: white;
        color: #667eea;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
      }

      .ri-arrow-right-line:hover {
        transform: scale(1.1) rotate(45deg);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
      }

      .ri-pencil-line {
        color: white;
        background: rgba(255, 255, 255, 0.2);
      }

      .ri-pencil-line:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: scale(1.1);
      }

      .ri-delete-bin-line {
        background: white;
        color: #e74c3c;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
      }

      .ri-delete-bin-line:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 20px rgba(231, 76, 60, 0.4);
      }

      /* Empty State */
      .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        border: 2px dashed rgba(255, 255, 255, 0.3);
        border-radius: 20px;
        color: rgba(255, 255, 255, 0.8);
        font-size: 1.1rem;
      }

      .empty-state::before {
        content: '📝';
        font-size: 3rem;
        display: block;
        margin-bottom: 1rem;
      }

      /* Responsive Design */
      @media (max-width: 768px) {
        nav {
          padding: 1rem;
          flex-direction: column;
          gap: 1rem;
        }

        .navlinks {
          gap: 1rem;
        }

        .hisaabs {
          padding: 1.5rem;
        }

        .hisaab {
          flex-direction: column;
          gap: 1rem;
          text-align: center;
        }

        .hisaabs h3 {
          font-size: 2rem;
        }
      }

      /* Loading Animation */
      .loading {
        opacity: 0;
        transform: translateY(30px);
      }
    </style>
  </head>

  <body>
    <main class="w-full h-screen font-['Helvetica']">
      <nav class="flex justify-between items-center">
        <h3 class="tracking-tight">Hisab-kitab App</h3>
        <div class="navlinks flex">
          <a class="tracking-tight" href="/">Home</a>
          <a class="tracking-tight" href="/create">Create New Hisaab</a>
        </div>
      </nav>
      
      <div class="hisaabs">
        <h3 class="capitalize font-medium tracking-tight">
          All hisaab kitaab
        </h3>

        <% if(files.length > 0) { %>
          <% files.forEach((file) => { %>
            <div class="hisaab loading">
              <div class="flex gap-4 text-white items-center">
                <h3>
                  <%= file.split(".")[0] %>
                </h3>
                <a href="/hisaab/<%= file %>">
                  <i class="ri-arrow-right-line"></i>
                </a>
              </div>
              <div class="flex gap-3 items-center">
                <a href="/edit/<%= file %>">
                  <i class="ri-pencil-line"></i>
                </a>
                <a href="/delete/<%= file %>">
                  <i class="ri-delete-bin-line"></i>
                </a>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="empty-state loading">
            Nothing to show, create hisaabs to see something.
          </div>
        <% } %>
      </div>
    </main>

    <script>
      // GSAP Animations
      gsap.registerPlugin();

      // Initial page load animation
      gsap.timeline()
        .from("nav", {
          y: -100,
          opacity: 0,
          duration: 1,
          ease: "power3.out"
        })
        .from(".hisaabs h3", {
          x: -50,
          opacity: 0,
          duration: 0.8,
          ease: "power2.out"
        }, "-=0.5")
        .to(".loading", {
          opacity: 1,
          y: 0,
          duration: 0.6,
          stagger: 0.1,
          ease: "power2.out"
        }, "-=0.3");

      // Hover animations for hisaab cards
      document.querySelectorAll('.hisaab').forEach(card => {
        card.addEventListener('mouseenter', () => {
          gsap.to(card.querySelector('h3'), {
            scale: 1.05,
            duration: 0.3,
            ease: "power2.out"
          });
        });

        card.addEventListener('mouseleave', () => {
          gsap.to(card.querySelector('h3'), {
            scale: 1,
            duration: 0.3,
            ease: "power2.out"
          });
        });
      });

      // Icon click animations
      document.querySelectorAll('.hisaab i').forEach(icon => {
        icon.addEventListener('click', (e) => {
          gsap.to(icon, {
            scale: 0.9,
            duration: 0.1,
            yoyo: true,
            repeat: 1,
            ease: "power2.inOut"
          });
        });
      });

      // Floating background animation
      gsap.to("body::before", {
        rotation: 360,
        duration: 20,
        repeat: -1,
        ease: "none"
      });

      // Parallax effect on scroll
      window.addEventListener('scroll', () => {
        const scrolled = window.pageYOffset;
        const parallax = document.querySelector('body::before');
        const speed = scrolled * 0.5;
        
        gsap.set('body::before', {
          transform: `translateY(${speed}px)`
        });
      });
    </script>
  </body>
</html>