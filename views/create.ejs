<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create New Hisaab - Hisab-kitab App</title>
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* Background Animation */
      body::before {
        content: "";
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(
            circle at 20% 80%,
            rgba(120, 119, 198, 0.3) 0%,
            transparent 50%
          ),
          radial-gradient(
            circle at 80% 20%,
            rgba(255, 255, 255, 0.1) 0%,
            transparent 50%
          ),
          radial-gradient(
            circle at 40% 40%,
            rgba(120, 119, 198, 0.2) 0%,
            transparent 50%
          );
        z-index: -1;
        animation: float 20s ease-in-out infinite;
      }

      @keyframes float {
        0%,
        100% {
          transform: translateY(0px) rotate(0deg);
        }
        50% {
          transform: translateY(-20px) rotate(1deg);
        }
      }

      main {
        position: relative;
        z-index: 1;
      }

      /* Navigation Styles */
      nav {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        padding: 1rem 2.5rem;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      }

      nav h3 {
        font-size: 1.8rem;
        font-weight: 700;
        color: white;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      nav h3::before {
        content: "📊";
        font-size: 1.5rem;
      }

      .navlinks {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .navlinks a {
        color: rgba(255, 255, 255, 0.9);
        text-decoration: none;
        font-weight: 500;
        padding: 0.5rem 1rem;
        border-radius: 25px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
      }

      .navlinks a::before {
        content: "";
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.2),
          transparent
        );
        transition: left 0.5s;
      }

      .navlinks a:hover::before {
        left: 100%;
      }

      .navlinks a:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
      }

      /* Main Content */
      .hisaabs {
        padding: 2.5rem;
        max-width: 800px;
        margin: 0 auto;
      }

      .hisaabs h3 {
        font-size: 2.5rem;
        font-weight: 600;
        color: white;
        margin-bottom: 2rem;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
        position: relative;
        text-align: center;
      }

      .hisaabs h3::after {
        content: "";
        position: absolute;
        bottom: -10px;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 4px;
        background: linear-gradient(90deg, #fff, transparent);
        border-radius: 2px;
      }

      /* Form Container */
      .form-container {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 25px;
        padding: 3rem;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        position: relative;
        overflow: hidden;
      }

      .form-container::before {
        content: "";
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.1),
          transparent
        );
        transition: left 0.8s;
      }

      .form-container:hover::before {
        left: 100%;
      }

      /* Form Elements */
      .form-group {
        margin-bottom: 2rem;
        position: relative;
      }

      .form-label {
        display: block;
        color: white;
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 1.1rem;
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
      }

      .form-input {
        width: 100%;
        padding: 1rem 1.5rem;
        background: rgba(255, 255, 255, 0.9);
        border: 2px solid transparent;
        border-radius: 15px;
        font-size: 1rem;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
      }

      .form-input:focus {
        outline: none;
        border-color: #667eea;
        background: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
      }

      .form-input::placeholder {
        color: #999;
        font-style: italic;
      }

      .form-textarea {
        width: 100%;
        padding: 1.5rem;
        background: rgba(255, 255, 255, 0.9);
        border: 2px solid transparent;
        border-radius: 15px;
        font-size: 1rem;
        min-height: 300px;
        resize: vertical;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        font-family: inherit;
      }

      .form-textarea:focus {
        outline: none;
        border-color: #667eea;
        background: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
      }

      .form-textarea::placeholder {
        color: #999;
        font-style: italic;
      }

      /* Submit Button */
      .submit-btn {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1rem 2.5rem;
        border: none;
        border-radius: 50px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0 auto;
      }

      .submit-btn::before {
        content: "";
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.2),
          transparent
        );
        transition: left 0.5s;
      }

      .submit-btn:hover::before {
        left: 100%;
      }

      .submit-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 35px rgba(102, 126, 234, 0.6);
      }

      .submit-btn:active {
        transform: translateY(-1px);
      }

      .submit-btn::after {
        content: "✨";
        margin-left: 0.5rem;
      }

      /* Floating Icons */
      .floating-icon {
        position: absolute;
        color: rgba(255, 255, 255, 0.3);
        font-size: 2rem;
        animation: floatIcon 6s ease-in-out infinite;
      }

      .floating-icon:nth-child(1) {
        top: 20%;
        left: 10%;
        animation-delay: 0s;
      }

      .floating-icon:nth-child(2) {
        top: 60%;
        right: 15%;
        animation-delay: 2s;
      }

      .floating-icon:nth-child(3) {
        bottom: 20%;
        left: 20%;
        animation-delay: 4s;
      }

      @keyframes floatIcon {
        0%,
        100% {
          transform: translateY(0px) rotate(0deg);
          opacity: 0.3;
        }
        50% {
          transform: translateY(-20px) rotate(5deg);
          opacity: 0.6;
        }
      }

      /* Responsive Design */
      @media (max-width: 768px) {
        nav {
          padding: 1rem;
          flex-direction: column;
          gap: 1rem;
        }

        .navlinks {
          gap: 1rem;
        }

        .hisaabs {
          padding: 1.5rem;
        }

        .form-container {
          padding: 2rem;
        }

        .hisaabs h3 {
          font-size: 2rem;
        }

        .form-input,
        .form-textarea {
          padding: 1rem;
        }
      }

      /* Loading Animation */
      .loading {
        opacity: 0;
        transform: translateY(30px);
      }
    </style>
  </head>

  <body>
    <main class="w-full h-screen font-['Helvetica']">
      <!-- Floating Background Icons -->
      <div class="floating-icon">💰</div>
      <div class="floating-icon">📝</div>
      <div class="floating-icon">💳</div>

      <nav class="flex justify-between items-center">
        <h3 class="tracking-tight">Hisab kitaab</h3>
        <div class="navlinks flex">
          <a class="tracking-tight" href="/">Home</a>
          <a class="tracking-tight" href="/create">Create New Hisaab</a>
        </div>
      </nav>

      <div class="hisaabs">
        <h3 class="capitalize font-medium tracking-tight loading">
          create new hisaab
        </h3>

        <div class="form-container loading">
          <form action="/createhisaab" method="post">
            <div class="form-group">
              <label class="form-label" for="title">
                <i class="ri-edit-line"></i> Hisaab Title
              </label>
              <input
                id="title"
                name="title"
                class="form-input"
                type="text"
                placeholder="Shopping ka hisaab, ghar ka kharch..."
                required
              />
            </div>

            <div class="form-group">
              <label class="form-label" for="content">
                <i class="ri-file-text-line"></i> Hisaab Details
              </label>
              <textarea
                id="content"
                name="content"
                class="form-textarea"
                placeholder="Write your hisaab details here... 
                
For example:
• Grocery - ₹500
• Vegetables - ₹200  
• Milk - ₹100
• Total - ₹800"
                required
              ></textarea>
            </div>

            <button type="submit" class="submit-btn">
              <i class="ri-save-line"></i>
              Create Hisaab
            </button>
          </form>
        </div>
      </div>
    </main>

    <script>
      // GSAP Animations
      gsap.registerPlugin();

      // Initial page load animation
      gsap
        .timeline()
        .from("nav", {
          y: -100,
          opacity: 0,
          duration: 1,
          ease: "power3.out",
        })
        .from(
          ".floating-icon",
          {
            scale: 0,
            rotation: 180,
            opacity: 0,
            duration: 0.8,
            stagger: 0.2,
            ease: "back.out(1.7)",
          },
          "-=0.5"
        )
        .to(
          ".loading",
          {
            opacity: 1,
            y: 0,
            duration: 0.8,
            stagger: 0.2,
            ease: "power2.out",
          },
          "-=0.3"
        );

      // Form input animations
      document
        .querySelectorAll(".form-input, .form-textarea")
        .forEach((input) => {
          input.addEventListener("focus", () => {
            gsap.to(input, {
              scale: 1.02,
              duration: 0.3,
              ease: "power2.out",
            });

            gsap.to(input.previousElementSibling, {
              scale: 1.05,
              color: "#667eea",
              duration: 0.3,
              ease: "power2.out",
            });
          });

          input.addEventListener("blur", () => {
            gsap.to(input, {
              scale: 1,
              duration: 0.3,
              ease: "power2.out",
            });

            gsap.to(input.previousElementSibling, {
              scale: 1,
              color: "white",
              duration: 0.3,
              ease: "power2.out",
            });
          });
        });

      // Submit button animation
      document.querySelector(".submit-btn").addEventListener("click", (e) => {
        const btn = e.target;

        gsap
          .timeline()
          .to(btn, {
            scale: 0.95,
            duration: 0.1,
            ease: "power2.out",
          })
          .to(btn, {
            scale: 1.05,
            duration: 0.2,
            ease: "back.out(1.7)",
          })
          .to(btn, {
            scale: 1,
            duration: 0.1,
            ease: "power2.out",
          });
      });

      // Floating icons animation
      gsap.to(".floating-icon", {
        y: -20,
        rotation: 5,
        duration: 3,
        ease: "power1.inOut",
        yoyo: true,
        repeat: -1,
        stagger: 1,
      });

      // Form container hover effect
      document
        .querySelector(".form-container")
        .addEventListener("mouseenter", () => {
          gsap.to(".form-container", {
            scale: 1.02,
            duration: 0.3,
            ease: "power2.out",
          });
        });

      document
        .querySelector(".form-container")
        .addEventListener("mouseleave", () => {
          gsap.to(".form-container", {
            scale: 1,
            duration: 0.3,
            ease: "power2.out",
          });
        });

      // Character counter for textarea
      const textarea = document.querySelector(".form-textarea");
      const counter = document.createElement("div");
      counter.style.cssText = `
        position: absolute;
        bottom: 10px;
        right: 15px;
        color: #999;
        font-size: 0.8rem;
        pointer-events: none;
      `;
      textarea.parentElement.style.position = "relative";
      textarea.parentElement.appendChild(counter);

      textarea.addEventListener("input", () => {
        const length = textarea.value.length;
        counter.textContent = `${length} characters`;

        if (length > 500) {
          counter.style.color = "#e74c3c";
        } else if (length > 300) {
          counter.style.color = "#f39c12";
        } else {
          counter.style.color = "#999";
        }
      });
    </script>
  </body>
</html>
