<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Hisaab - Hisab-kitaab App</title>
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* Background Animation */
      body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: 
          radial-gradient(circle at 20% 80%, rgba(120, 119, 198, 0.3) 0%, transparent 50%),
          radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
          radial-gradient(circle at 40% 40%, rgba(120, 119, 198, 0.2) 0%, transparent 50%);
        z-index: -1;
        animation: float 20s ease-in-out infinite;
      }

      @keyframes float {
        0%, 100% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(1deg); }
      }

      main {
        position: relative;
        z-index: 1;
      }

      /* Navigation Styles */
      nav {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        padding: 1rem 2.5rem;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      }

      nav h3 {
        font-size: 1.8rem;
        font-weight: 700;
        color: white;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      nav h3::before {
        content: '📊';
        font-size: 1.5rem;
      }

      .navlinks {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .navlinks a {
        color: rgba(255, 255, 255, 0.9);
        text-decoration: none;
        font-weight: 500;
        padding: 0.5rem 1rem;
        border-radius: 25px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
      }

      .navlinks a::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.5s;
      }

      .navlinks a:hover::before {
        left: 100%;
      }

      .navlinks a:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
      }

      /* Main Content */
      .hisaabs {
        padding: 2.5rem;
        max-width: 900px;
        margin: 0 auto;
      }

      .edit-header {
        text-align: center;
        margin-bottom: 3rem;
      }

      .edit-header h3 {
        font-size: 2.2rem;
        font-weight: 600;
        color: white;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
        margin-bottom: 1rem;
        line-height: 1.3;
      }

      .filename-highlight {
        background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-weight: 700;
        text-shadow: none;
        position: relative;
      }

      .filename-highlight::after {
        content: '';
        position: absolute;
        bottom: -5px;
        left: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
        border-radius: 2px;
        animation: glow 2s ease-in-out infinite alternate;
      }

      @keyframes glow {
        from { box-shadow: 0 0 5px #ffd700; }
        to { box-shadow: 0 0 20px #ffd700, 0 0 30px #ffd700; }
      }

      .edit-subtitle {
        color: rgba(255, 255, 255, 0.8);
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
      }

      /* Form Container */
      .form-container {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 25px;
        padding: 3rem;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        position: relative;
        overflow: hidden;
      }

      .form-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
        transition: left 0.8s;
      }

      .form-container:hover::before {
        left: 100%;
      }

      /* Textarea Styles */
      .edit-textarea {
        width: 100%;
        padding: 2rem;
        background: rgba(255, 255, 255, 0.95);
        border: 2px solid transparent;
        border-radius: 20px;
        font-size: 1.1rem;
        min-height: 400px;
        resize: vertical;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        font-family: 'Courier New', monospace;
        line-height: 1.6;
        outline: none;
      }

      .edit-textarea:focus {
        border-color: #667eea;
        background: white;
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(102, 126, 234, 0.3);
      }

      .edit-textarea::placeholder {
        color: #999;
        font-style: italic;
      }

      /* Textarea Label */
      .textarea-label {
        display: block;
        color: white;
        font-weight: 600;
        margin-bottom: 1rem;
        font-size: 1.2rem;
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      /* Character Counter */
      .char-counter {
        position: absolute;
        bottom: 15px;
        right: 20px;
        color: #666;
        font-size: 0.9rem;
        background: rgba(255, 255, 255, 0.8);
        padding: 0.3rem 0.8rem;
        border-radius: 15px;
        pointer-events: none;
        transition: all 0.3s ease;
      }

      /* Action Buttons */
      .action-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 2rem;
      }

      .btn {
        padding: 1rem 2.5rem;
        border: none;
        border-radius: 50px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
      }

      .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
      }

      .btn-secondary {
        background: rgba(255, 255, 255, 0.2);
        color: white;
        border: 2px solid rgba(255, 255, 255, 0.3);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
      }

      .btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.5s;
      }

      .btn:hover::before {
        left: 100%;
      }

      .btn:hover {
        transform: translateY(-3px);
      }

      .btn-primary:hover {
        box-shadow: 0 15px 35px rgba(102, 126, 234, 0.6);
      }

      .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.3);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
      }

      .btn:active {
        transform: translateY(-1px);
      }

      /* Floating Icons */
      .floating-icon {
        position: absolute;
        color: rgba(255, 255, 255, 0.2);
        font-size: 2rem;
        animation: floatIcon 8s ease-in-out infinite;
      }

      .floating-icon:nth-child(1) {
        top: 15%;
        left: 8%;
        animation-delay: 0s;
      }

      .floating-icon:nth-child(2) {
        top: 70%;
        right: 10%;
        animation-delay: 3s;
      }

      .floating-icon:nth-child(3) {
        bottom: 15%;
        left: 15%;
        animation-delay: 6s;
      }

      @keyframes floatIcon {
        0%, 100% { transform: translateY(0px) rotate(0deg); opacity: 0.2; }
        50% { transform: translateY(-30px) rotate(10deg); opacity: 0.4; }
      }

      /* Responsive Design */
      @media (max-width: 768px) {
        nav {
          padding: 1rem;
          flex-direction: column;
          gap: 1rem;
        }

        .navlinks {
          gap: 1rem;
        }

        .hisaabs {
          padding: 1.5rem;
        }

        .form-container {
          padding: 2rem;
        }

        .edit-header h3 {
          font-size: 1.8rem;
        }

        .edit-textarea {
          padding: 1.5rem;
          min-height: 300px;
        }

        .action-buttons {
          flex-direction: column;
          align-items: center;
        }

        .btn {
          width: 100%;
          max-width: 300px;
          justify-content: center;
        }
      }

      /* Loading Animation */
      .loading {
        opacity: 0;
        transform: translateY(30px);
      }

      /* Auto-save indicator */
      .auto-save {
        position: fixed;
        top: 20px;
        right: 20px;
        background: rgba(46, 204, 113, 0.9);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 25px;
        font-size: 0.9rem;
        opacity: 0;
        transform: translateY(-20px);
        transition: all 0.3s ease;
        z-index: 1000;
      }

      .auto-save.show {
        opacity: 1;
        transform: translateY(0);
      }
    </style>
  </head>

  <body>
    <main class="w-full h-screen font-['Helvetica']">
      <!-- Floating Background Icons -->
      <div class="floating-icon">✏️</div>
      <div class="floating-icon">📝</div>
      <div class="floating-icon">💾</div>

      <!-- Auto-save indicator -->
      <div class="auto-save" id="autoSaveIndicator">
        <i class="ri-save-line"></i> Auto-saved
      </div>

      <nav class="flex justify-between items-center">
        <h3 class="tracking-tight">Hisab-kitaab</h3>
        <div class="navlinks flex">
          <a class="tracking-tight" href="/">Home</a>
          <a class="tracking-tight" href="/create">Create New Hisaab</a>
        </div>
      </nav>
      
      <div class="hisaabs">
        <div class="edit-header loading">
          <h3 class="font-medium tracking-tight">
            You're editing hisaab of
            <span class="filename-highlight"><%= filename.split(".")[0] %></span>
          </h3>
          <div class="edit-subtitle">
            <i class="ri-calendar-line"></i>
            <span>Last modified: <span id="lastModified">Just now</span></span>
          </div>
        </div>

        <div class="form-container loading">
          <form action="/update/<%= filename %>" method="post" id="editForm">
            <label class="textarea-label" for="content">
              <i class="ri-file-edit-line"></i>
              Edit Your Hisaab Content
            </label>
            <div style="position: relative;">
              <textarea
                id="content"
                class="edit-textarea"
                placeholder="Write your hisaab details here..."
                name="content"
                required
              ><%= filedata %></textarea>
              <div class="char-counter" id="charCounter">0 characters</div>
            </div>

            <div class="action-buttons">
              <button type="submit" class="btn btn-primary">
                <i class="ri-save-line"></i>
                Update Hisaab
              </button>
              <a href="/" class="btn btn-secondary">
                <i class="ri-arrow-left-line"></i>
                Cancel
              </a>
            </div>
          </form>
        </div>
      </div>
    </main>

    <script>
      // GSAP Animations
      gsap.registerPlugin();

      // Initial page load animation
      gsap.timeline()
        .from("nav", {
          y: -100,
          opacity: 0,
          duration: 1,
          ease: "power3.out"
        })
        .from(".floating-icon", {
          scale: 0,
          rotation: 180,
          opacity: 0,
          duration: 0.8,
          stagger: 0.3,
          ease: "back.out(1.7)"
        }, "-=0.5")
        .to(".loading", {
          opacity: 1,
          y: 0,
          duration: 0.8,
          stagger: 0.2,
          ease: "power2.out"
        }, "-=0.3");

      // Textarea focus animations
      const textarea = document.getElementById('content');
      const charCounter = document.getElementById('charCounter');

      textarea.addEventListener('focus', () => {
        gsap.to(textarea, {
          scale: 1.02,
          duration: 0.3,
          ease: "power2.out"
        });
        
        gsap.to('.textarea-label', {
          scale: 1.05,
          color: "#ffd700",
          duration: 0.3,
          ease: "power2.out"
        });
      });

      textarea.addEventListener('blur', () => {
        gsap.to(textarea, {
          scale: 1,
          duration: 0.3,
          ease: "power2.out"
        });
        
        gsap.to('.textarea-label', {
          scale: 1,
          color: "white",
          duration: 0.3,
          ease: "power2.out"
        });
      });

      // Character counter functionality
      function updateCharCounter() {
        const length = textarea.value.length;
        charCounter.textContent = `${length} characters`;
        
        if (length > 1000) {
          charCounter.style.color = '#e74c3c';
          charCounter.style.background = 'rgba(231, 76, 60, 0.1)';
        } else if (length > 500) {
          charCounter.style.color = '#f39c12';
          charCounter.style.background = 'rgba(243, 156, 18, 0.1)';
        } else {
          charCounter.style.color = '#666';
          charCounter.style.background = 'rgba(255, 255, 255, 0.8)';
        }
      }

      textarea.addEventListener('input', updateCharCounter);
      updateCharCounter(); // Initial count

      // Auto-save functionality (visual feedback only)
      let autoSaveTimeout;
      textarea.addEventListener('input', () => {
        clearTimeout(autoSaveTimeout);
        autoSaveTimeout = setTimeout(() => {
          showAutoSave();
        }, 2000);
      });

      function showAutoSave() {
        const indicator = document.getElementById('autoSaveIndicator');
        indicator.classList.add('show');
        setTimeout(() => {
          indicator.classList.remove('show');
        }, 2000);
      }

      // Button animations
      document.querySelectorAll('.btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          gsap.timeline()
            .to(btn, {
              scale: 0.95,
              duration: 0.1,
              ease: "power2.out"
            })
            .to(btn, {
              scale: 1.05,
              duration: 0.2,
              ease: "back.out(1.7)"
            })
            .to(btn, {
              scale: 1,
              duration: 0.1,
              ease: "power2.out"
            });
        });
      });

      // Floating icons animation
      gsap.to(".floating-icon", {
        y: -30,
        rotation: 10,
        duration: 4,
        ease: "power1.inOut",
        yoyo: true,
        repeat: -1,
        stagger: 2
      });

      // Form container hover effect
      document.querySelector('.form-container').addEventListener('mouseenter', () => {
        gsap.to('.form-container', {
          scale: 1.01,
          duration: 0.3,
          ease: "power2.out"
        });
      });

      document.querySelector('.form-container').addEventListener('mouseleave', () => {
        gsap.to('.form-container', {
          scale: 1,
          duration: 0.3,
          ease: "power2.out"
        });
      });

      // Filename highlight animation
      gsap.to('.filename-highlight::after', {
        scaleX: 0,
        duration: 1,
        ease: "power2.inOut",
        yoyo: true,
        repeat: -1
      });

      // Update last modified time
      function updateLastModified() {
        const now = new Date();
        const timeString = now.toLocaleTimeString();
        document.getElementById('lastModified').textContent = timeString;
      }

      // Update time every minute
      setInterval(updateLastModified, 60000);

      // Keyboard shortcuts
      document.addEventListener('keydown', (e) => {
        // Ctrl+S to save
        if (e.ctrlKey && e.key === 's') {
          e.preventDefault();
          document.getElementById('editForm').submit();
        }
        
        // Ctrl+Z for undo (browser default)
        // Ctrl+Y for redo (browser default)
      });

      // Show keyboard shortcuts hint
      setTimeout(() => {
        const hint = document.createElement('div');
        hint.innerHTML = `
          <div style="position: fixed; bottom: 20px; left: 20px; background: rgba(0,0,0,0.8); color: white; padding: 1rem; border-radius: 10px; font-size: 0.9rem; z-index: 1000;">
            <div><kbd>Ctrl+S</kbd> to save</div>
            <div><kbd>Ctrl+Z</kbd> to undo</div>
          </div>
        `;
        document.body.appendChild(hint);
        
        setTimeout(() => {
          gsap.to(hint, { opacity: 0, duration: 0.5, onComplete: () => hint.remove() });
        }, 3000);
      }, 2000);
    </script>
  </body>
</html>